# ─────────────────────────────────────────────
# AetherTrack AI — Environment Variables Example
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=aethertrack
POSTGRES_USER=aethertrack
POSTGRES_PASSWORD=changeme

# Redis
REDIS_PASSWORD=changeme

# JWT
JWT_SECRET=change-me-to-a-256bit-secret
JWT_EXPIRATION_MS=86400000

# Mail (MailHog dev defaults)
MAIL_HOST=mailhog
MAIL_PORT=1025

# App
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
